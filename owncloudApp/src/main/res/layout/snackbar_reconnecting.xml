<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/reconnecting_snackbar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="16dp"
    android:visibility="gone"
    app:cardBackgroundColor="@color/homecloud_reconnecting_snackbar_background"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    tools:visibility="visible">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/reconnecting_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/homecloud_reconnecting_title"
            android:textColor="@color/homecloud_reconnecting_snackbar_text"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/reconnecting_close_button"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/reconnecting_close_button"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/homecloud_close"
            android:src="@drawable/ic_close"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/homecloud_reconnecting_snackbar_text" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/reconnecting_progress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:indeterminate="true"
            app:indicatorColor="@color/homecloud_color_accent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/reconnecting_title"
            app:trackColor="@color/homecloud_progressbar_track"
            app:trackCornerRadius="2dp"
            app:trackThickness="4dp" />

        <TextView
            android:id="@+id/reconnecting_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/homecloud_reconnecting_message"
            android:textColor="@color/homecloud_reconnecting_snackbar_text"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/reconnecting_progress" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
